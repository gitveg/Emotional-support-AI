# ===================================================
# Emotional-Support-AI 配置文件
# ===================================================
# 复制此文件为 .env.local 并填入你的配置

# AI 模型 API 密钥（必填）
# 支持 OpenAI 格式的 API，如 OpenAI / DeepSeek / 月之暗面 / 智谱等
OPENAI_API_KEY=your_api_key_here

# API 基础地址（可选，默认使用 OpenAI 官方地址）
# 如使用 DeepSeek: https://api.deepseek.com
# 如使用月之暗面 (Kimi): https://api.moonshot.cn/v1
# 如使用智谱 AI: https://open.bigmodel.cn/api/paas/v4
OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的模型名称（可选，默认 gpt-4o-mini）
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# DeepSeek: deepseek-chat
# 月之暗面: moonshot-v1-8k
# 智谱: glm-4
AI_MODEL=gpt-4o-mini
